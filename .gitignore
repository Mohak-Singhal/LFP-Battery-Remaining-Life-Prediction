# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Ignore directories by default
/models/*
/results/*

# But explicitly track completed artifact pipelines so Render doesn't re-train (OOM crash)
!/models/*.pkl
!/models/*.json
!/results/*.parquet
!/results/*.json
streamlit.log

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
